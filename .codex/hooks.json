{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HY_HOME_HOOK_PROVIDER=codex bash \"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/hooks/agent-event-hook.sh\" SessionStart",
            "timeout": 600
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HY_HOME_HOOK_PROVIDER=codex bash \"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/hooks/agent-event-hook.sh\" PreToolUse",
            "timeout": 600
          }
        ],
        "matcher": "Bash|Read|Glob|Grep|LS|Edit|Write|MultiEdit|apply_patch|ApplyPatch"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HY_HOME_HOOK_PROVIDER=codex bash \"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/hooks/agent-event-hook.sh\" PostToolUse",
            "timeout": 600
          }
        ],
        "matcher": "Edit|Write|MultiEdit|apply_patch|ApplyPatch"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HY_HOME_HOOK_PROVIDER=codex bash \"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/hooks/agent-event-hook.sh\" Stop",
            "timeout": 600
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HY_HOME_HOOK_PROVIDER=codex bash \"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/hooks/agent-event-hook.sh\" PreCompact",
            "timeout": 600
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HY_HOME_HOOK_PROVIDER=codex bash \"${CODEX_PROJECT_DIR:-$(git rev-parse --show-toplevel)}/scripts/hooks/agent-event-hook.sh\" UserPromptSubmit",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
