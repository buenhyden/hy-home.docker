{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/agent-event-hook.sh SessionStart",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Glob|Grep|LS|Edit|Write|MultiEdit|apply_patch|ApplyPatch",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/agent-event-hook.sh PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|apply_patch|ApplyPatch",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/agent-event-hook.sh PostToolUse",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
